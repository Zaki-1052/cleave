# cleave/.env.example

# Database
DATABASE_URL=postgresql+asyncpg://cleave:dev@localhost:5432/cleave
TEST_DATABASE_URL=postgresql+asyncpg://cleave:dev@localhost:5432/cleave_test

# Auth
SECRET_KEY=change-me-in-production-min-32chars!!
REFRESH_SECRET_KEY=change-me-too-in-production-min-32ch!!
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false  # MUST be true in production (HTTPS required for secure cookies)

# App
CORS_ORIGINS=http://localhost:5173
STORAGE_ROOT=/data/cleave
UPLOAD_MAX_SIZE_MB=5000
PIPELINE_MODE=mock

# File serving (production only)
NGINX_FILE_SERVING=false
NGINX_INTERNAL_PREFIX=/internal-files/

# Worker
WORKER_POLL_INTERVAL_SECONDS=2

# Trimmomatic JVM heap size — caps each concurrent Trimmomatic process to prevent
# OOM when many pairs trim in parallel. With MAX_CONCURRENT_REACTIONS=8, worst case
# is 8 × 4g = 32GB. Increase if trimming very large FASTQ files (>20M reads).
TRIMMOMATIC_HEAP_SIZE=4g

# Email (Amazon SES — leave empty for local dev, emails will be skipped)
AWS_SES_REGION=
AWS_SES_FROM_EMAIL=
APP_URL=http://localhost:5173

# Password reset token lifetime (seconds)
RESET_TOKEN_LIFETIME_SECONDS=3600

# Genomes (Phase 3)
GENOME_INDEX_DIR=/data/cleave/genomes

# Storage Lifecycle (Phase 7.1)
CLEANUP_ENABLED=true
CLEANUP_INTERVAL_HOURS=24
LOG_RETENTION_DAYS=30
STORAGE_QUOTA_BYTES=0
TUS_STAGING_RETENTION_HOURS=48
